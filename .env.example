# Optional display title shown in the browser tab.
NEXT_PUBLIC_DASHBOARD_NAME="Daily Dashboard"

# Entur Journey Planner API configuration.
ENTUR_CLIENT_NAME=andre-status-page
ENTUR_STOP_PLACE_ID=NSR:StopPlace:YOUR_STOP_ID_HERE

# Google Calendar OAuth configuration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_REFRESH_TOKEN=
# Use "all" for visible calendars, or a comma-separated list like primary,calendar_id_2.
GOOGLE_CALENDAR_IDS=all
# Legacy fallback when GOOGLE_CALENDAR_IDS is not set.
GOOGLE_CALENDAR_ID=primary
