# Optional display title shown in the browser tab.
NEXT_PUBLIC_DASHBOARD_NAME="Daily Dashboard"

# Entur Journey Planner API configuration.
ENTUR_CLIENT_NAME=andre-status-page
ENTUR_STOP_PLACE_ID=NSR:StopPlace:YOUR_STOP_ID_HERE

# Workout leaderboard.
# Leave this true for local UI development without real friend tokens.
WORKOUT_LEADERBOARD_USE_MOCK=true

# Friend token variables referenced from src/lib/workoutFriends.ts.
# Strava refresh tokens must have access to /api/v3/athlete/activities.
# Hevy tokens are sent server-side as the Hevy API key.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

STRAVA_REFRESH_TOKEN_ANDRE=
HEVY_API_TOKEN_ANDRE=

STRAVA_REFRESH_TOKEN_FRIEND_1=
HEVY_API_TOKEN_FRIEND_1=

STRAVA_REFRESH_TOKEN_FRIEND_2=
HEVY_API_TOKEN_FRIEND_2=
